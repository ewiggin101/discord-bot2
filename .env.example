# ─────────────────────────────────────────────
#  TranslatorBot — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# DeepL API Key (Free or Pro)
# Get from: https://www.deepl.com/pro-api
# Free tier: 500,000 characters/month
DEEPL_API_KEY=your_deepl_api_key_here

# Naver Papago API (Naver Cloud Platform)
# Get from: https://www.ncloud.com/ → AI Services → Papago Translation
# Free tier: 10,000 characters/day
PAPAGO_CLIENT_ID=your_papago_client_id_here
PAPAGO_CLIENT_SECRET=your_papago_client_secret_here
